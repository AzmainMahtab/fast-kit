# Matching ID for alambic processes
UID=1000
GID=1000

# ENVIRONMENT: local | production
ENVIRONMENT=local

# PROJECT
PROJECT_NAME=FastAPI Backend
API_V1_PREFIX=/api/v1
DEBUG=false

# DATABASE
POSTGRES_HOST=postgres
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_secure_password_123
POSTGRES_DB=app_db
POSTGRES_PORT=5432

# FOR ALEMBIC MIGRATIONS
DATABASE_URL=postgresql+asyncpg://app_user:app_secure_password_123@postgres:5432/app_db

# REDIS
REDIS_URL=redis://redis:6379/0

# SECURITY
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# FIRST SUPERUSER (auto-created on startup)
# DEVELOPMENT ONLY — override in production with a strong password (>= 12 characters)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=ChangeThisInProduction123!
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PHONE_NUMBER=+1234567890

# EMAIL (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=App

# FILE UPLOADS
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=["jpg","jpeg","png","pdf","doc","docx"]

# PAGINATION
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

